{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skills-scanner-www-redirect",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-01",
  "workers_dev": true,
  "env": {
    "staging": {
      "name": "skills-scanner-www-redirect-staging"
    },
    "production": {
      "name": "skills-scanner-www-redirect",
      "routes": [
        {
          "pattern": "www.scanskill.dev",
          "custom_domain": true
        }
      ]
    }
  }
}
