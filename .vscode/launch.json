{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Full Stack (Turbo)",
      "program": "${workspaceFolder}/node_modules/turbo/bin/turbo",
      "args": ["run", "dev", "--parallel"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Wrangler Dev (All Queues)",
      "program": "${workspaceFolder}/node_modules/wrangler/bin/wrangler.js",
      "args": [
        "dev",
        "--local",
        "--port",
        "8787",
        "-c",
        "backend/wrangler.jsonc",
        "-c",
        "workers/worker1/wrangler.jsonc",
        "-c",
        "workers/worker2/wrangler.jsonc",
        "-c",
        "workers/worker3/wrangler.jsonc"
      ],
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full Stack + Backend Debug",
      "configurations": ["Debug Full Stack (Turbo)", "Debug Backend API (Wrangler)"],
      "stopAll": true
    },
    {
      "name": "Wrangler Dev (All Queues)",
      "configurations": ["Debug Wrangler Dev (All Queues)"],
      "stopAll": true
    }
  ]
}
